{
  "name": "forgepad-agent",
  "version": "0.1.0",
  "description": "ForgePad desktop agent for secure Android-to-desktop coding sessions.",
  "license": "MIT",
  "private": false,
  "type": "module",
  "bin": {
    "forgepad": "dist/index.js"
  },
  "files": [
